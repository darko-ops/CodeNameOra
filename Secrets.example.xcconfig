// ORA — Secrets template (Section 8).
//
// Copy this file to `Secrets.xcconfig` (gitignored) and fill in real values.
// project.yml wires Secrets.xcconfig as the Debug/Release config file, and the
// keys below are surfaced to Swift via Info.plist + Config.swift.
//
// ⚠️ xcconfig gotcha: a literal `//` starts a comment, so a raw URL like
// https://example.com is truncated at `https:`. Escape it by splitting the
// slashes with the build-setting trick:  VALUE = https:/$()/example.com
// or store only the host and rebuild the URL in code. The placeholders below
// avoid `//` on purpose.

SPOTIFY_CLIENT_ID = your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET = your_spotify_client_secret_here
SUPABASE_URL = your-project.supabase.co
SUPABASE_ANON_KEY = your_supabase_anon_key_here
REVENUECAT_API_KEY = your_revenuecat_api_key_here
STRAVA_CLIENT_ID = your_strava_client_id_here
STRAVA_CLIENT_SECRET = your_strava_client_secret_here
SENTRY_DSN = your_sentry_dsn_here
POSTHOG_API_KEY = your_posthog_key_here
GETSONGBPM_API_KEY = your_getsongbpm_api_key_here
